                a.small.fw-bold(href="#all-projects", style="color: #667eea; text-decoration: none;")
                  i.bi.bi-arrow-up.me-1
                  span Retour aux projets
              .row.g-4
                each project in categoryProjects
                  .col-12
                    .project-card(style="background: rgba(255, 255, 255, 0.94); border-radius: 1.25rem; overflow: hidden; box-shadow: 0 10px 32px rgba(45, 55, 72, 0.08); border: 1px solid rgba(255, 255, 255, 0.72); transition: all 0.35s ease;")
                      .row.g-0.align-items-stretch
                        .col-lg-4
                          .image-container.project-image-placeholder(style="height: 100%; min-height: 240px;")
                            if project.image
                              img(src=project.image, alt=project.imageAlt || project.title, style="width: 100%; height: 100%; min-height: 240px; object-fit: cover;")
                            else
                              .text-center(style="color: #667eea;")
                                i.bi(style="font-size: 3rem;", class=project.icon)
                                p.mt-3.mb-0.fw-bold(style="color: #4a5568;")= project.imageLabel
                        .col-lg-8
                          .p-4.p-lg-5
                            span.badge.mb-3(style="background: #2d3748; color: white; padding: 0.45rem 0.75rem; border-radius: 999px; font-size: 0.78rem;")= project.meta
                            h3.fw-bold.mb-3(style="color: #2d3748;")= project.title
                            p.mb-2(style="color: #4a5568; line-height: 1.7;")= project.summary
                            p.mb-3(style="color: #5f6b7a; line-height: 1.7;")= project.details
                            .tech-badges(style="display: flex; flex-wrap: wrap; gap: 0.45rem;")
                              each tag in project.tags
                                span.badge(style="background: #edf2f7; color: #2d3748; border: 1px solid rgba(45, 55, 72, 0.08); padding: 0.42rem 0.72rem; border-radius: 0.65rem; font-size: 0.78rem;")= tag
                            a.btn.btn-primary.mt-4(href=project.link, target="_blank", style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; border-radius: 1.5rem; padding: 0.72rem 1.5rem; font-weight: 600; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.32); transition: all 0.3s ease;")
                              i.bi.me-2(class=project.linkIcon || 'bi-github')
