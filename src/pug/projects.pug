          .text-center.mb-4(style="animation: fadeInDown 0.8s ease-out;")
            h1.display-4.fw-bolder.mb-3
              span.gradient-text(style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;") Mes Projets
            p.lead(style="color: #4a5568; max-width: 760px; margin: 0 auto;") Une sélection de projets académiques et techniques en IA, systèmes intelligents, sécurité, web, microservices et mobile.

          .project-filter-nav.mb-5(style="position: sticky; top: 0.75rem; z-index: 5; background: rgba(255, 255, 255, 0.86); backdrop-filter: blur(16px); border: 1px solid rgba(102, 126, 234, 0.18); border-radius: 1rem; padding: 0.85rem; box-shadow: 0 10px 30px rgba(45, 55, 72, 0.08);")
            .d-flex.flex-wrap.justify-content-center.gap-2
              a.btn.btn-sm(href="#all-projects", style="background: #2d3748; color: white; border-radius: 999px; padding: 0.55rem 1rem; font-weight: 700; transition: all 0.2s ease;")
                i.bi.bi-grid.me-1
                span Tous
              each category in categories
                a.btn.btn-sm(href=`#${category.id}`, style="background: white; color: #2d3748; border: 1px solid rgba(45, 55, 72, 0.14); border-radius: 999px; padding: 0.55rem 1rem; font-weight: 700; transition: all 0.2s ease;")
                  i.bi.me-1(class=category.icon)
                  span= category.label

          #all-projects.row.g-4
            each project, index in projects
              .col-lg-6
                .project-card.h-100(style=`background: rgba(255, 255, 255, 0.94); backdrop-filter: blur(20px); border-radius: 1.25rem; overflow: hidden; box-shadow: 0 10px 32px rgba(45, 55, 72, 0.09); border: 1px solid rgba(255, 255, 255, 0.72); transition: all 0.35s ease; animation: fadeInUp 0.6s ease-out ${0.1 + index * 0.08}s both;`)
                  .image-container.project-image-placeholder(style="position: relative; overflow: hidden;")
                    if project.image
                      img(src=project.image, alt=project.imageAlt || project.title, style="width: 100%; height: 100%; min-height: 245px; object-fit: cover; transition: transform 0.4s ease;")
                    else
                      .text-center(style="color: #667eea;")
                        i.bi(style="font-size: 3.25rem;", class=project.icon)
                        p.mt-3.mb-0.fw-bold(style="color: #4a5568;")= project.imageLabel
                    .overlay(style="position: absolute; inset: 0; background: linear-gradient(135deg, rgba(102, 126, 234, 0.72), rgba(56, 178, 172, 0.72)); opacity: 0; transition: opacity 0.3s ease;")
                  .p-4
                    .d-flex.flex-wrap.align-items-center.gap-2.mb-3
                      span.badge(style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 0.45rem 0.75rem; border-radius: 999px; font-size: 0.78rem;")= project.meta
                      a.small.fw-bold(href=`#${project.category}`, style="color: #667eea; text-decoration: none;") Voir la catégorie
                    h2.fw-bold.mb-3(style="color: #2d3748; font-size: 1.45rem; line-height: 1.25;")= project.title
                    p.mb-2(style="color: #4a5568; line-height: 1.65;")= project.summary
                    p.mb-3(style="color: #5f6b7a; line-height: 1.65;")= project.details
                    .tech-badges(style="display: flex; flex-wrap: wrap; gap: 0.45rem;")
                      each tag in project.tags
                        span.badge(style="background: #edf2f7; color: #2d3748; border: 1px solid rgba(45, 55, 72, 0.08); padding: 0.42rem 0.72rem; border-radius: 0.65rem; font-size: 0.78rem;")= tag
                    a.btn.btn-primary.mt-4(href=project.link, target="_blank", style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; border-radius: 1.5rem; padding: 0.72rem 1.5rem; font-weight: 600; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.32); transition: all 0.3s ease;")
                      i.bi.me-2(class=project.linkIcon || 'bi-github')
                      span= project.linkLabel || 'Voir sur GitHub'

          each category in categories
            - const categoryProjects = projects.filter((project) => project.category === category.id)
            section.mt-5(id=category.id, style="scroll-margin-top: 7rem;")
              .d-flex.align-items-center.justify-content-between.flex-wrap.gap-3.mb-3
                h2.fw-bolder.mb-0(style="color: #2d3748; font-size: 1.65rem;")
